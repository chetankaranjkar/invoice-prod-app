# =========================
# .gitignore for .NET + Node (React)
# =========================

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Build outputs
bin/
obj/
publish/
artifacts/

# Rider
.idea/

# npm / node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/

# React / front-end
invoice-app/build/
invoice-app/.env
/invoice-app/.cache

# Logs
*.log

# OS
Thumbs.db
.DS_Store

# User secrets (.NET)
secrets.json
appsettings.Development.json

# Local DB / SQLite / EF?
*.mdf
*.ldf
*.sqlite

# VS Code (if used)
.vscode/

# Others you may want
*.zip
*.7z
*.tar.gz

# If you use JetBrains:
.idea/

# Git LFS: large files would be tracked explicitly
